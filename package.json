{
  "name": "code-cubicle",
  "displayName": "CodeCubicle",
  "description": "Visualizes GitHub Copilot agent and subagent activity as pixel art office workers in a tiny animated office.",
  "version": "0.5.0",
  "publisher": "code-cubicle",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pmelander/code-cubicle.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeCubicle.open",
        "title": "CodeCubicle: Open Office"
      },
      {
        "command": "codeCubicle.reset",
        "title": "CodeCubicle: Reset Office"
      },
      {
        "command": "codeCubicle.simulate",
        "title": "CodeCubicle: Run Simulation"
      },
      {
        "command": "codeCubicle.toggleCapture",
        "title": "CodeCubicle: Toggle Output Capture"
      }
    ]
  },
  "scripts": {
    "compile": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "lint": "eslint \"src/**/*.ts\" \"webview/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vscode-test",
    "package": "vsce package --no-dependencies",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@eslint/js": "^8.57.1",
    "@types/node": "^18.19.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.20.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^7.18.0",
    "vitest": "^1.2.0"
  }
}
